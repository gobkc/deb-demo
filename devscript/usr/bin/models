#!/bin/bash

DEFAULT_MODEL_DIR="."

MODEL_SOURCE=$(echo -e "Single model file\nDirectory containing models" | peco --prompt "Select model source: ")

case $MODEL_SOURCE in
    "Single model file")
        mapfile -t model_files < <(find "$DEFAULT_MODEL_DIR" -maxdepth 1 -type f -name "*.gguf" 2>/dev/null | sort)
        if [ ${#model_files[@]} -eq 0 ]; then
            echo "No .gguf files found in current directory. Please enter full path manually."
            read -p "Model file path: " MODEL_PATH
        else
            MODEL_PATH=$(printf "%s\n" "${model_files[@]}" | peco --prompt "Select a model file: ")
            if [ -z "$MODEL_PATH" ]; then
                echo "No model selected. Exiting."
                exit 1
            fi
        fi
        ;;
    "Directory containing models")
        CURRENT_DIR=$(pwd)
        mapfile -t subdirs_abs < <(find "$DEFAULT_MODEL_DIR" -maxdepth 1 -type d ! -path "$DEFAULT_MODEL_DIR" -exec realpath {} \; 2>/dev/null | sort)
        choices="$CURRENT_DIR"
        for d in "${subdirs_abs[@]}"; do
            choices="$choices\n$d"
        done
        choices="$choices\nManual input path"
        selected=$(echo -e "$choices" | peco --prompt "Select a directory (or manual input): ")
        if [ "$selected" = "Manual input path" ]; then
            read -p "Enter directory path: " MODEL_PATH
            MODEL_PATH=$(realpath "$MODEL_PATH" 2>/dev/null || (cd "$MODEL_PATH" && pwd))
        else
            MODEL_PATH="$selected"
        fi
        if [ -z "$MODEL_PATH" ] || [ ! -d "$MODEL_PATH" ]; then
            echo "Invalid directory. Exiting."
            exit 1
        fi
        ;;
    *)
        echo "Invalid selection"
        exit 1
        ;;
esac

read -p "Enter number of layers to offload to GPU (-ngl) [default 200]: " NGL
NGL=${NGL:-200}

read -p "Enter web server port [default 8080]: " PORT
PORT=${PORT:-8080}

echo "--- Optional Performance Parameters ---"
read -p "Enable Flash Attention (-fa)? (y/n) [default y]: " fa_choice
if [[ "$fa_choice" =~ ^[Nn]$ ]]; then
    FA=""
else
    FA="-fa"
fi

read -p "Batch size for prompt processing (-b) [default 2048]: " BATCH
BATCH=${BATCH:-2048}

read -p "Micro batch size (-ub) [default 1024]: " UBATCH
UBATCH=${UBATCH:-1024}

read -p "Number of threads for generation (-t) [default 4]: " THREADS
THREADS=${THREADS:-4}

read -p "Number of threads for batch processing (-tb) [default 16]: " THREADS_BATCH
THREADS_BATCH=${THREADS_BATCH:-16}

read -p "Number of parallel requests (-np) [default 4]: " PARALLEL
PARALLEL=${PARALLEL:-4}

read -p "Enable NUMA optimizations (--numa)? (y/n) [default y]: " numa_choice
if [[ "$numa_choice" =~ ^[Nn]$ ]]; then
    NUMA=""
else
    NUMA="--numa"
fi

read -p "Temperature (--temp) [default 0.7]: " TEMP
TEMP=${TEMP:-0.7}

CMD="llama-server -m \"$MODEL_PATH\" -ngl $NGL --port $PORT $FA -b $BATCH -ub $UBATCH -t $THREADS -tb $THREADS_BATCH -np $PARALLEL $NUMA --temp $TEMP"

echo -e "\033[0;32mCommand to execute:\033[0m $CMD"
echo "Starting server..."

eval $CMD
